{
  "name": "pure-survey-platform-backend",
  "version": "1.0.0",
  "description": "Backend API for PURE Survey Platform - Complete Survey Management System with 2FA, reCAPTCHA, and Advanced Security",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:setup": "node src/seeders/run.js",
    "db:migrate": "node src/migrations/run.js",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix"
  },
  "keywords": [
    "survey",
    "forms",
    "2fa",
    "recaptcha",
    "authentication",
    "security",
    "postgresql",
    "express",
    "nodejs",
    "sequelize",
    "jwt"
  ],
  "author": "PURE Survey Platform",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "6.11.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.3",
    "sequelize": "^6.35.1",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "jest": "^29.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pure-survey/platform-backend.git"
  },
  "bugs": {
    "url": "https://github.com/pure-survey/platform-backend/issues"
  },
  "homepage": "https://pure-survey.com",
  "private": true
}